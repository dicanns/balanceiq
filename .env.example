# BalanceIQ environment secrets — copy to .env and fill in real values
# See README or ask team lead for actual values
# NEVER commit .env to version control

# Sentry error tracking (https://sentry.io)
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
VITE_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# Supabase project (renderer-side)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Square POS OAuth secrets
SQUARE_SANDBOX_APP_SECRET=sandbox-sq0csb-your_sandbox_secret_here
SQUARE_APP_SECRET=your_production_square_secret_here

# Clover POS OAuth secret
CLOVER_SANDBOX_APP_SECRET=your_clover_sandbox_secret_here
CLOVER_APP_SECRET=your_clover_production_secret_here

# Shopify POS OAuth secret
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here
