{
  "name": "balanceiq",
  "version": "1.0.0",
  "description": "L'intelligence derrière vos chiffres.",
  "main": "main.js",
  "scripts": {
    "start": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "vite": "vite",
    "electron": "electron .",
    "build": "vite build && electron-builder --mac && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "electron-builder --win",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.balanceiq.app",
    "productName": "BalanceIQ",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "**/*",
      "!node_modules/**/better-sqlite3/build/Release/.deps/**"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "dmg": {
      "title": "BalanceIQ ${version}",
      "backgroundColor": "#0c0e14",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 130, "y": 220, "type": "file" },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "asarUnpack": ["**/*.node"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BalanceIQ"
    }
  }
}
